#!/bin/bash
# ============================================================
# install-archgaming — Arch Gaming OS Installer
# ============================================================
# Installer interattivo per Arch Gaming OS.
# Eseguire dalla live ISO: sudo install-archgaming
#
# Operazioni:
#   1. Selezione disco target
#   2. Partizionamento GPT (ESP + Swap + BTRFS)
#   3. Creazione subvolumes BTRFS
#   4. Pacstrap con lista pacchetti gaming
#   5. Configurazione di sistema
#   6. Installazione bootloader (systemd-boot)
#   7. Creazione utente gaming
#   8. Copia configurazioni gaming
#   9. Reboot
# ============================================================

set -euo pipefail

# ---- Colori ----
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}>>> ${NC}$1"; }
ok()    { echo -e "${GREEN}[OK]${NC} $1"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

# ---- Verifica root ----
[[ $EUID -ne 0 ]] && error "Esegui come root: sudo install-archgaming"

echo ""
echo -e "${CYAN}============================================================${NC}"
echo -e "${CYAN}        Arch Gaming OS — Installer${NC}"
echo -e "${CYAN}============================================================${NC}"
echo ""

# ---- 1. Selezione disco ----
info "Dischi disponibili:"
lsblk -d -o NAME,SIZE,MODEL,TYPE | grep disk
echo ""
read -rp "Disco target (es. sda, nvme0n1): " DISK_NAME
DISK="/dev/${DISK_NAME}"

[[ ! -b "$DISK" ]] && error "Disco $DISK non trovato"

echo ""
warn "TUTTI I DATI SU $DISK VERRANNO CANCELLATI!"
read -rp "Conferma (digita YES): " CONFIRM
[[ "$CONFIRM" != "YES" ]] && error "Installazione annullata."

# ---- Determina suffisso partizione (p per nvme, nulla per sda) ----
if [[ "$DISK" == *"nvme"* ]] || [[ "$DISK" == *"mmcblk"* ]]; then
    PART_PREFIX="${DISK}p"
else
    PART_PREFIX="${DISK}"
fi

# ---- 2. Partizionamento ----
info "Partizionamento $DISK..."
sgdisk --zap-all "${DISK}"
sgdisk -n 1:0:+512M -t 1:ef00 "${DISK}"   # ESP
sgdisk -n 2:0:+8G   -t 2:8200 "${DISK}"   # Swap
sgdisk -n 3:0:0     -t 3:8300 "${DISK}"   # Root BTRFS
ok "Partizionamento completato"

# ---- 3. Formattazione ----
info "Formattazione..."
mkfs.fat -F32 "${PART_PREFIX}1"
mkswap "${PART_PREFIX}2"
mkfs.btrfs -f -L archgaming "${PART_PREFIX}3"
ok "Formattazione completata"

# ---- 4. Subvolumes BTRFS ----
info "Creazione subvolumes BTRFS..."
mount "${PART_PREFIX}3" /mnt
btrfs subvolume create /mnt/@
btrfs subvolume create /mnt/@home
btrfs subvolume create /mnt/@var_log
btrfs subvolume create /mnt/@var_cache
btrfs subvolume create /mnt/@snapshots
umount /mnt

# Rimonta con subvolumes
BTRFS_OPTS="compress=zstd:1,noatime,discard=async"
mount -o "subvol=@,${BTRFS_OPTS}" "${PART_PREFIX}3" /mnt
mkdir -p /mnt/{boot,home,var/log,var/cache,.snapshots}
mount -o "subvol=@home,${BTRFS_OPTS}" "${PART_PREFIX}3" /mnt/home
mount -o "subvol=@var_log,${BTRFS_OPTS}" "${PART_PREFIX}3" /mnt/var/log
mount -o "subvol=@var_cache,${BTRFS_OPTS}" "${PART_PREFIX}3" /mnt/var/cache
mount -o "subvol=@snapshots,${BTRFS_OPTS}" "${PART_PREFIX}3" /mnt/.snapshots
mount "${PART_PREFIX}1" /mnt/boot
swapon "${PART_PREFIX}2"
ok "Subvolumes BTRFS creati e montati"

# ---- 5. Pacstrap ----
info "Installazione sistema base (questo richiede qualche minuto)..."
pacstrap -K /mnt \
    base linux linux-firmware btrfs-progs mkinitcpio \
    base-devel git zstd bc kmod libelf pahole cpio perl tar xz \
    clang llvm lld \
    networkmanager sudo nano gptfdisk dosfstools pacman-contrib \
    intel-ucode amd-ucode \
    mesa lib32-mesa vulkan-radeon lib32-vulkan-radeon \
    vulkan-icd-loader lib32-vulkan-icd-loader \
    libva-mesa-driver lib32-libva-mesa-driver \
    mesa-vdpau lib32-mesa-vdpau xf86-video-amdgpu \
    gamescope wayland xorg-xwayland wlroots \
    pipewire pipewire-pulse pipewire-alsa pipewire-jack lib32-pipewire wireplumber \
    vulkan-tools mesa-utils libinput \
    steam gamemode lib32-gamemode mangohud lib32-mangohud cpupower \
    plymouth polkit
ok "Pacstrap completato"

# ---- 6. Genera fstab ----
info "Generazione fstab..."
genfstab -U /mnt >> /mnt/etc/fstab
ok "fstab generato"

# ---- 7. Copia config e script gaming nel chroot ----
info "Staging configurazioni gaming..."
mkdir -p /mnt/tmp/gaming-configs

# Config files dall'overlay della live ISO
cp /etc/sysctl.d/99-gaming.conf /mnt/tmp/gaming-configs/99-gaming-sysctl.conf 2>/dev/null || true
cp /etc/udev/rules.d/60-ioschedulers.rules /mnt/tmp/gaming-configs/ 2>/dev/null || true
cp /etc/security/limits.d/99-gaming.conf /mnt/tmp/gaming-configs/99-gaming-limits.conf 2>/dev/null || true
cp /etc/modprobe.d/gpu.conf /mnt/tmp/gaming-configs/ 2>/dev/null || true
cp /etc/pacman.d/hooks/00-btrfs-snapshot.hook /mnt/tmp/gaming-configs/ 2>/dev/null || true
cp /etc/pacman.d/hooks/95-systemd-boot.hook /mnt/tmp/gaming-configs/ 2>/dev/null || true
cp /etc/polkit-1/rules.d/49-gaming-power.rules /mnt/tmp/gaming-configs/ 2>/dev/null || true

# Scripts
for script in gaming-poweroff gaming-reboot gaming-suspend gaming-update pacman-snapshot; do
    cp /usr/local/bin/${script} /mnt/tmp/gaming-configs/ 2>/dev/null || true
done

# Gaming tool configs (da /configs/ sulla ISO se presenti, o dalla home skel)
cp /etc/skel/.config/MangoHud/MangoHud.conf /mnt/tmp/gaming-configs/ 2>/dev/null || true
cp /etc/gamemode.ini /mnt/tmp/gaming-configs/ 2>/dev/null || true

# Skel files (bash_profile, gamescope service) — necessari per post-install
cp /etc/skel/.bash_profile /mnt/tmp/gaming-configs/ 2>/dev/null || true
cp /etc/skel/.config/systemd/user/gamescope-session.service /mnt/tmp/gaming-configs/ 2>/dev/null || true

ok "Config gaming staged"

# ---- 8. Post-install in chroot ----
info "Configurazione sistema in chroot..."
cp /usr/local/bin/post-install-chroot /mnt/tmp/post-install-chroot
chmod +x /mnt/tmp/post-install-chroot

ROOT_UUID=$(blkid -s UUID -o value "${PART_PREFIX}3")
export ROOT_UUID
arch-chroot /mnt /tmp/post-install-chroot "$ROOT_UUID"
rm -rf /mnt/tmp/post-install-chroot /mnt/tmp/gaming-configs
ok "Configurazione chroot completata"

# ---- 9. Cleanup ----
info "Smontaggio..."
umount -R /mnt
swapoff "${PART_PREFIX}2"

echo ""
echo -e "${GREEN}============================================================${NC}"
echo -e "${GREEN}  Installazione completata!${NC}"
echo -e "${GREEN}  Rimuovi la USB e riavvia: reboot${NC}"
echo -e "${GREEN}============================================================${NC}"
echo ""
